{
  "$schema": "./registry-component.schema.json",
  "name": "menu-trigger",
  "description": "Button that toggles a menu open/closed, with ARIA and anchor positioning",
  "directives": [
    {
      "type": "MenuTrigger",
      "importPath": "@terseware/ui/menu"
    },
    {
      "type": "MenuDisabled",
      "importPath": "@terseware/ui/menu",
      "inputs": {"menuDisabled": "disabled"}
    },
    {
      "type": "MenuExpanded",
      "importPath": "@terseware/ui/menu",
      "inputs": {"menuExpanded": "expanded"}
    }
  ],
  "core": ["MenuTrigger"],
  "optional": ["MenuDisabled", "MenuExpanded"],
  "registryDependencies": ["menu"]
}
