{
  "$schema": "https://json-schema.org/schema",
  "cli": "nx",
  "id": "forge-add",
  "title": "Forge Add",
  "description": "Generate a @terseware/ui component wrapper",
  "type": "object",
  "properties": {
    "component": {
      "type": "string",
      "description": "Component name from the registry (e.g., button, menu)",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "prefix": {
      "type": "string",
      "description": "Component prefix override"
    },
    "inputs": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Input mappings (e.g., hardDisabled:disabled)"
    },
    "template": {
      "type": "string",
      "description": "Named template for Mode 2 generation"
    },
    "preset": {
      "type": "string",
      "description": "Named preset for Mode 3 generation"
    },
    "dryRun": {
      "type": "boolean",
      "description": "Preview output without writing files",
      "default": false
    }
  },
  "required": ["component"]
}
