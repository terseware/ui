{
  "name": "forge",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/forge/src",
  "projectType": "library",
  "tags": ["cli"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/forge",
        "main": "packages/forge/src/index.ts",
        "tsConfig": "packages/forge/tsconfig.lib.json",
        "assets": [
          "packages/forge/src/registry/components/*.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "coverage/packages/forge"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "cli": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "FORGE_CLI=$NX_WORKSPACE_ROOT/dist/packages/forge/src/cli.js && node $FORGE_CLI"
      },
      "configurations": {
        "examples": {
          "cwd": "apps/examples"
        }
      }
    },
    "local-cli": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "chmod +x dist/packages/forge/src/cli.js && pnpm link --global dist/packages/forge"
      }
    }
  }
}
